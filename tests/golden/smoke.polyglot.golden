__ap_v1="$#"
printf '%s\n' 'argc='"${__ap_v1}"
__ap_v2=0
__ap_v3=1
__ap_t0=5
while [ "$__ap_v3" -le "$__ap_t0" ]; do
  __ap_v2="$((__ap_v2 + __ap_v3))"
  __ap_v3=$((__ap_v3 + 1))
done
