#!/bin/sh
function REM() { return; }
REM @'
REM '; : << 'APPLOWS_BATCH'
@echo off
set "APPLOWS_SELF=%~f0"
powershell -NoProfile -ExecutionPolicy Bypass -Command "$u=New-Object System.Text.UTF8Encoding $false; $s=[System.IO.File]::ReadAllText($env:APPLOWS_SELF,$u); $b=[ScriptBlock]::Create($s); & $b @args; exit $LASTEXITCODE" %*
exit /b %ERRORLEVEL%
APPLOWS_BATCH
# ==== Applows sh payload (macOS /bin/sh + zsh) ====
__ap_f0() {
