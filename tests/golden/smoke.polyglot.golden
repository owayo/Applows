if [ "${__ap_v2}" -eq 15 ]; then
  printf '%s\n' 'sum ok'
else
  printf '%s\n' 'sum bad'
fi
__ap_f0 'hello'
for __ap_v4 in "$@"; do
  printf '%s\n' 'arg='"${__ap_v4}"
done
printf '%s\n' 'smoke end'
exit 0
exit 0
'@
# ==== Applows PowerShell payload (Windows 11) ====
$__ap_args = $args
$global:__ap_ret = 0
try { [Console]::OutputEncoding = New-Object System.Text.UTF8Encoding $false } catch {}
$ErrorActionPreference = 'Stop'
function __ap_f0 {
